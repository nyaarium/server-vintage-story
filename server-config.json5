{
    startOptions: {
        start: {
            label: "Start Server",
            role: "user",
            command: ["bash", "start.sh", "game"],
        },
        updateMods: {
            label: "Update Mods",
            role: "admin",
            command: ["bash", "start.sh", "mod-updater", "update"],
        },
        checkOutdated: {
            label: "Check For Updates",
            role: "admin",
            command: ["bash", "start.sh", "mod-updater", "outdated"],
        },
    },
    ports: [
        { port: 42420, protocol: "tcp" },
    ],
    patterns: {
        ready: "\\[Event\\] Dedicated Server now running",
        playerJoin: "\\[Event\\] (\\S+) .*joins\\.",
        playerLeave: "\\[Event\\] Player (\\S+) (?:left|got removed)\\.",
    },
    logging: {
        mode: "file",
        files: ["/root/app/data/logs/server-main.log"],
    },
    stopAction: {
        type: "stdin",
        command: "/stop",
        enterDelaySec: 60,
        forceKillSec: 300,
    },
}
